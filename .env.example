# 复制为 .env 后按需修改
PORT=8000

# 上传限制
MAX_UPLOAD_SIZE_MB=500
MAX_FILES_PER_JOB=20

# 模型
MODEL_NAME=iic/SenseVoiceSmall
MODEL_DEVICE=cpu

# ────────── 模型本地路径（指向 ./data/models/ 下已下载的目录） ──────────
# 留空则自动从 ModelScope 下载到 /root/.cache/modelscope
# 推荐先用 python scripts/download_model.py 离线下载到 ./data/models/
MODEL_DIR=/app/models/sensevoice
VAD_MODEL_DIR=/app/models/vad
PUNC_MODEL_DIR=/app/models/punc

# N100 4C4T 推理优化
USE_QUANTIZE=true          # ONNX int8 量化（用上 N100 的 VNNI 指令）
INTRA_OP_THREADS=3         # 推理线程，留 1 核给 ffmpeg/系统
INTER_OP_THREADS=1
FFMPEG_THREADS=1           # 16kHz 抽音 1 线程足够
SINGLE_FLIGHT=true         # 同时只跑一个识别任务

# 任务
JOB_TTL_SECONDS=3600
