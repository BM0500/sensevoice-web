# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# 前端构建产物 / 依赖
frontend/node_modules/
frontend/dist/
frontend/.vite/
**/*.tsbuildinfo

# 运行时数据（含大模型文件，不入仓）
data/

# 日志
logs/
*.log

# 环境变量（避免泄露本机配置 / 端口 / 路径）
.env
.env.local
.env.*.local
# 但 .env.example 和 .env.nas 是模板，必须入仓

# IDE / 编辑器
.vscode/
.idea/
.DS_Store

# Claude Code 本地设置（个人化的 hook 配置，不应入仓）
.claude/